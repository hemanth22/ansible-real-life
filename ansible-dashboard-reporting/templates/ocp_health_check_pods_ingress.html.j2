{% if pod_list_ingress.resources is defined %}
<div class="center">
  <h3>Ingress Operator Pods</h3>
  <table>
    <tr>
    <th style="text-align: left;padding: 5px;">Pod Name</th>
    <th style="text-align: left;padding: 5px;">Status</th>
    <th style="text-align: left;padding: 5px;">Container Status</th>
    <th style="text-align: left;padding: 5px;">IP Address</th>
    <th style="text-align: left;padding: 5px;">Host</th>
    </tr>
    <tbody>

    {% for pod in pod_list_ingress.resources %}
    <tr>
    <td style="text-align: left;padding: 5px;" valign="top" align="center">
      <strong>{{ pod.metadata.name }}</strong>
    </td>

    <td style="text-align: left;padding: 5px;" valign="top" align="center">
      {{ pod.status.phase | default('NA') }}
    </td>

    <td style="text-align: left;padding: 5px;" valign="top" align="center">
      {%if pod.status.containerStatuses | length > 0 %} 
        {% for container in pod.status.containerStatuses %}
          {{ container.name }}: {{ container.ready }}<br>     
        {% endfor %}
      {% endif %}
      
    </td>

    <td style="text-align: left;padding: 5px;" valign="top" align="center">
      {{ pod.status.podIP | default('NA') }}
    </td>

    <td style="text-align: left;padding: 5px;" valign="top" align="center">
      {{ pod.spec.nodeName | default('NA') }}
    </td>

    </tr>
    {% endfor %}
    </tbody>
    </table>
</div>
{% endif %}