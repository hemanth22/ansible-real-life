<!DOCTYPE html PUBLIC "-//W3C//DTD XHTML 1.0 Transitional//EN" "https://www.w3.org/TR/xhtml1/DTD/xhtml1-transitional.dtd">
<html xmlns="https://www.w3.org/1999/xhtml">
<head>
<title>{{ dns_report_title }}</title>
<meta http–equiv="Content-Type" content="text/html; charset=UTF-8" />
<meta http–equiv="X-UA-Compatible" content="IE=edge" />
<meta name="viewport" content="width=device-width, initial-scale=1.0 " />
<style>
body {
background-color: #eeeeee;
font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
}
</style>
</head>
<body class="em_body" style="margin:0px; padding:0px;" >
<table class="em_full_wrap" valign="top" width="100%" cellspacing="0" cellpadding="0" border="0" bgcolor="#efefef" align="center">
<tbody><tr>
<td valign="top" align="center">
<table class="em_main_table" style="width:700px;" width="700" cellspacing="0" cellpadding="0" border="0" align="center">
<!-- Header section -->
<tbody><tr>
<td style="padding:15px;" class="em_padd" valign="top" bgcolor="#f6f7f8" align="center"><table width="100%" cellspacing="0" cellpadding="0" border="0" align="center">
<tbody><tr>
<td style="font-size:12px; line-height:15px; color:#646464;" valign="top" align="center">This Report is Generated by Ansible Automation<!--| <a href="#" target="_blank" style="color:#0d1121; text-decoration:underline;">View Online</a>-->
</td>
</tr>
</tbody></table>
</td>
</tr>
<tr>
<td valign="top" align="center"><table width="100%" cellspacing="0" cellpadding="0" border="0" align="center">
<tbody><tr>
<td valign="top" align="center">
<h2>{{ dns_report_title }}</h2>
</tr>
</tbody></table></td>
</tr>
<!--Content section-->
<tr>
<td valign="top" align="center" style="padding-bottom: 15px;">
<table width="100%" cellspacing="0" cellpadding="0" border="0" align="center">
<tr>
<th style="text-align: left;padding: 5px;">DNS Server</th>
<th style="text-align: left;padding: 5px;">Validation Result</th>
</tr>
<tbody>
<!-- Content from DNS Verification Result : dns_verification_summary_final -->
{% for dns_servers in dns_verification_summary_final.values() %}
<tr>
<td style="text-align: left;padding: 5px;" valign="top" align="center"><strong>{{ dns_servers.dns_server_name }}<br>({{ dns_servers.dns_server_ip }})</strong></td>
<td style="text-align: left;padding: 5px;" valign="top" align="center">
<strong>URLs Matching with Redirect IP: {{ dns_servers.success_count }}</strong><br>
<strong>URLs NOT Matching with Redirect IP: {{ dns_servers.failed_count }}</strong> (See below)<br>
{% for host_not_matched in dns_servers.failed_hosts %}
{{ host_not_matched }}," "
{% endfor %}
</td>
</tr>
{% endfor %}
<!-- end of DNS Verification result-->
</tbody>
</table>
</td>
</tr>
<!--//Content section--> 

<!--Content Text Section-->
<tr>
<td style="padding:35px 70px 30px;" class="em_padd" valign="top" bgcolor="#0d1121" align="center"><table width="100%" cellspacing="0" cellpadding="0" border="0" align="center">
<tbody><tr>
<td style="font-size:16px; line-height:30px; color:#ffffff;" valign="top" align="center">This Report was generated by Ansible as part DNS Deployment & Verification.</td>
</tr>
<tr>
<td style="font-size:0px; line-height:0px; height:15px;" height="15">&nbsp;</td>
<!--—this is space of 15px to separate two paragraphs —-->
</tr>
<tr>
<td style="font-size:18px; line-height:22px; color:#fbeb59; padding-bottom:12px;" valign="top" align="center">Please report to <a href="mailto:{{ dns_report_admin_email }}" target="_blank" style="text-decoration:none; color:#fbeb59;">{{ dns_report_admin_email }}</a> if you find any issues in the Report.</td>
</tr>
<tr>
<td class="em_h20" style="font-size:0px; line-height:0px; height:25px;" height="25">&nbsp;</td>
</tr>
<tr>
<td style="font-size:18px; line-height:22px; color:#fbeb59; text-transform:uppercase; padding-bottom:12px;" valign="top" align="center">Thank You</td>
</tr>
</tbody></table></td>
</tr>
<!--Footer Section-->
<tr>
<td style="font-size:11px; line-height:18px; color:#999999;" valign="top" align="center"><a href="#" target="_blank" style="color:#999999; text-decoration:underline;">PRIVACY STATEMENT</a> | <br>
If you do not wish to receive any further emails, please report to <a href="mailto:{{ dns_report_admin_email }}" target="_blank" style="text-decoration:none; color:#999999;">{{ dns_report_admin_email }}</a></td>
</tr>
</tbody></table></td>
</tr>
<tr>
<td class="em_hide" style="line-height:1px;min-width:700px;background-color:#ffffff;"></td>
</tr>
</tbody></table></td>
</tr>
</tbody></table>
<div class="em_hide" style="white-space: nowrap; display: none; font-size:0px; line-height:0px;">&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp;</div>
</body></html>