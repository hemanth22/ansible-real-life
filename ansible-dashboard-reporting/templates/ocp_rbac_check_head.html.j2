<head>
    <title>{{ health_report_title | default('OpenShift RBAC Report') }}</title>
    <meta http–equiv="Content-Type" content="text/html; charset=UTF-8" />
    <meta http–equiv="X-UA-Compatible" content="IE=edge" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0 " />
    {% raw %}
    <style>
    body {
      background-color: #eee;
      font-family: "Red Hat Text", -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif, "Apple Color Emoji", "Segoe UI Emoji", "Segoe UI Symbol";
      line-height: 150%;
    }
    .center {
      border: 0px solid;
      margin: auto;
      width: 98%; 
      padding: 10px 20px 20px 20px;
      text-align: center;
      background-color: #fff;
      display: grid;
      /* grid-template-columns: repeat(auto-fit, minmax(250px, 1fr)); */
      overflow-x: auto;
    }
    .snippet {
      font-family: ui-monospace, 
                 Menlo, Monaco, 
                 "Cascadia Mono", "Segoe UI Mono", 
                 "Roboto Mono", 
                 "Oxygen Mono", 
                 "Ubuntu Monospace", 
                 "Source Code Pro",
                 "Fira Mono", 
                 "Droid Sans Mono", 
                 "Courier New", monospace;
    }
    table {
      vertical-align: top;
      width: 100%;
      border-spacing: 0px;
      border: 1px solid #eee;
      border-collapse: collapse;
    }
    .table-head,
    .table-body{
        white-space: nowrap;
    }
    td, th {
      text-align: left;
      padding: 5px;
      vertical-align: top;
      border: 1px solid #eee;
    }
    th {
      padding-top: 5px;
      padding-bottom: 5px;
      background-color: #ccc;
    }
    .green-cell {
      background-color: #40f140;
    }
    .red-cell {
      background-color: #f14940;
      color: #fff;
    }
    .gray-cell {
      background-color: #b3b1af;
    }
    .stripe-cell {
      background-color: #eee;
    }
    .header-cell {
      align-content: center;
      text-align: center;
      background-color: #eee;
      padding: 10px;
    }
    .footer-text {
      font-size:16px; 
      color:#444444;
    }
    .footer {
      background-color: #eeeeee;
    }
    </style>
    {% endraw %} 
    </head>